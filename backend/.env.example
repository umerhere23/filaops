# FilaOps Environment Configuration
# ====================================
# Copy this file to .env and update values
#
# cp .env.example .env

# ===========================================
# DATABASE (Required)
# ===========================================
# PostgreSQL 16+ required
DB_HOST=localhost
DB_PORT=5432
DB_NAME=filaops
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
# Or provide a full URL (overrides DB_* settings above):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/filaops

# ===========================================
# SECURITY (Required)
# ===========================================
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
# API_KEY=optional-api-key-for-integrations

# Cookie security: false for local dev (no TLS), true for production (requires HTTPS)
COOKIE_SECURE=false
# Auth token delivery: 'cookie' (httpOnly, recommended) or 'header' (legacy bearer-in-body)
AUTH_MODE=cookie

# ===========================================
# ENVIRONMENT
# ===========================================
# Options: development, production
ENVIRONMENT=development
DEBUG=false

# ===========================================
# CORS (Required for frontend)
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# FRONTEND_URL=http://localhost:5173

# ===========================================
# TIER (Community Edition)
# ===========================================
# Options: community, pro, enterprise
TIER=community

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
# Options: json, text
LOG_FORMAT=json
# LOG_FILE=./logs/app.log
# AUDIT_LOG_FILE=./logs/audit.log

# ===========================================
# EMAIL / SMTP (Optional)
# ===========================================
# See docs/EMAIL_CONFIGURATION.md for details
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=Your Company Name
# SMTP_TLS=true

# ===========================================
# BUSINESS INFO (Optional)
# ===========================================
# ADMIN_APPROVAL_EMAIL=admin@example.com
# BUSINESS_EMAIL=info@yourcompany.com
# BUSINESS_NAME=Your Company Name

# ===========================================
# SHIP FROM ADDRESS (Optional - for shipping labels)
# ===========================================
# SHIP_FROM_NAME=Your Company Name
# SHIP_FROM_STREET1=123 Main Street
# SHIP_FROM_CITY=Your City
# SHIP_FROM_STATE=ST
# SHIP_FROM_ZIP=12345
# SHIP_FROM_COUNTRY=US
# SHIP_FROM_PHONE=555-555-5555

# ===========================================
# FILE STORAGE (Optional)
# ===========================================
# UPLOAD_DIR=./uploads/quotes
# MAX_FILE_SIZE_MB=100
# ALLOWED_FILE_FORMATS=.3mf,.stl

# ===========================================
# BAMBU PRINT SUITE (Optional)
# ===========================================
# BAMBU_SUITE_API_URL=http://localhost:8001
# BAMBU_SUITE_API_KEY=your-bambu-suite-api-key

# ===========================================
# EASYPOST SHIPPING (Optional)
# ===========================================
# EASYPOST_API_KEY=your-easypost-api-key
# EASYPOST_TEST_MODE=true

# ===========================================
# REDIS / BACKGROUND JOBS (Optional)
# ===========================================
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# SENTRY ERROR TRACKING (Optional)
# ===========================================
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project

# ===========================================
# GOOGLE DRIVE (Optional)
# ===========================================
ENABLE_GOOGLE_DRIVE=false

# ===========================================
# MRP SETTINGS (Optional — safe defaults)
# ===========================================
# INCLUDE_SALES_ORDERS_IN_MRP=false
# AUTO_MRP_ON_ORDER_CREATE=false
# AUTO_MRP_ON_SHIPMENT=false
# AUTO_MRP_ON_CONFIRMATION=false
# MRP_ENABLE_SUB_ASSEMBLY_CASCADING=false
# MRP_VALIDATION_STRICT_MODE=true

# ===========================================
# MANUFACTURING (Optional)
# ===========================================
# MACHINE_HOURLY_RATE=1.50
# MACHINE_TIME_SKU=MFG-MACHINE-TIME

# ===========================================
# PRICING (Optional — defaults in settings.py)
# ===========================================
# Material costs ($/gram)
# MATERIAL_COST_PLA=0.017
# MATERIAL_COST_PETG=0.017
# MATERIAL_COST_ABS=0.020
# MATERIAL_COST_ASA=0.020
# MATERIAL_COST_TPU=0.033
#
# Markup multipliers
# MARKUP_PLA=3.5
# MARKUP_PETG=3.5
# MARKUP_ABS=4.0
# MARKUP_ASA=4.0
# MARKUP_TPU=4.5
#
# MINIMUM_ORDER_VALUE=10.00
# QUOTE_EXPIRATION_DAYS=30
