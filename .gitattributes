# Auto detect text files and ensure LF line endings in the repo
* text=auto eol=lf

# Shell scripts must always use LF (break on CRLF in Linux containers)
*.sh text eol=lf
*.bash text eol=lf

# Env files — invisible \r breaks variable parsing in containers
*.env* text eol=lf

# Docker files
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Windows-specific files that need CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# 3D printing files
*.stl binary
*.3mf binary
